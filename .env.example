# 通义千问API配置
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 应用配置
APP_NAME=UCAP-Agent-Demo
APP_VERSION=1.0.0
DEBUG=true

# 数据库配置
DATABASE_PATH=./data/ucap_demo.db
DB_BACKEND=sqlite
# 如需切换到 Postgres，设置如下变量（并修改 docker-compose 中的 postgres 服务或外部地址）
# DATABASE_URL=postgresql://ucap:ucap_pwd@localhost:5432/ucap_demo

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Streamlit配置
STREAMLIT_PORT=8501
STREAMLIT_HOST=localhost

# 数据生成配置
ERP_DATA_SIZE=1000
HR_DATA_SIZE=500
FIN_DATA_SIZE=800

# 模型配置
DEFAULT_MODEL=qwen-turbo
MAX_TOKENS=2000
TEMPERATURE=0.7

# 缓存配置
ENABLE_REDIS_CACHE=false
REDIS_URL=redis://:redis@localhost:6379/0
